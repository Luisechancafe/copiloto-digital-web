# (Opcional) Endpoint para el form de /contacto. Si vacío, manda mailto.
NEXT_PUBLIC_CONTACT_ENDPOINT=

# (Opcional) ID GA4 si quiere medir
NEXT_PUBLIC_GA_ID=
