# URL del SaaS (para botones "Probar gratis" y "Iniciar sesión")
NEXT_PUBLIC_APP_URL=https://ia.copiloto.digital

# URL de la web pública (para canonical y OG)
NEXT_PUBLIC_SITE_URL=https://copiloto.digital

# Email de contacto (mostrado en /contacto)
